# ============================================================
# Nexus monolito — variaveis de ambiente
# Copie para .env (local) e configure no Railway (producao).
# ============================================================

# ------------------------------------------------------------
# BANCO (COMPARTILHADO pelos dois lados)
# ------------------------------------------------------------
# UMA url so. Formato psycopg3/libpq, com sslmode. O backend usa direto; a
# Oficina (db.py) converte sozinha pro formato asyncpg (tira o sslmode e
# troca o prefixo). NAO use o prefixo +asyncpg aqui.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# ------------------------------------------------------------
# BACKEND (API do jogo, /api/v1)
# ------------------------------------------------------------
# Bearer token de quem chama a API.
SERVICE_API_KEY=troque-isto-em-producao

# CORS: CSV de origens. UI e API estao no MESMO dominio (monolito), entao
# pode deixar "*" ou apontar pro proprio dominio.
CORS_ORIGINS=*

# "production" esconde /docs e /redoc. Use "dev" pra expor os docs.
# PARA TESTAR LOCAL: troque para  ENVIRONMENT=dev  (senao /docs nao aparece).
ENVIRONMENT=production

# Informativo (schema OpenAPI).
API_BASE_URL=https://app.luisgabriel.uk

# Sentry (observabilidade). Vazio = desligado.
SENTRY_DSN=

# Pool psycopg3 (defaults sensatos ja no config.py):
# DB_POOL_MIN=5
# DB_POOL_MAX=15

# ------------------------------------------------------------
# OFICINA — auth (Basic Auth single-user) + sessao NiceGUI
# ------------------------------------------------------------
# Usuario do Basic Auth que protege /oficina*.
OFICINA_USER=mestre

# Hash bcrypt da senha (NAO a senha em texto). Gere com:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'SUA_SENHA', bcrypt.gensalt(rounds=12)).decode())"
OFICINA_PASS_HASH=COLE_O_HASH_BCRYPT_AQUI

# Segredo pra assinar os cookies de sessao do NiceGUI (string aleatoria longa).
STORAGE_SECRET=troque-por-uma-string-aleatoria-longa

# ------------------------------------------------------------
# OFICINA — armazenamento de imagens (Cloudflare R2)
# ------------------------------------------------------------
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=
R2_PUBLIC_URL=

# ------------------------------------------------------------
# OFICINA — IA interna (opcional; so se usar o atelie de imagens)
# ------------------------------------------------------------
# OpenRouter aqui e uso interno da Oficina (NAO e o narrador do jogo; o
# narrador usa a API direta da Anthropic, fora deste monolito).
OPENROUTER_API_KEY=
